extends base

block content
  main.main
    .login-form
       h2.heading-secondary.ma-bt-lg Create an account
       form.form.form--signup
        .form__group
          label.form__label(for='name') Name
          input#name.form__input.n_signup(type='text', placeholder='Jhon Doe', required)
        .form__group
          label.form__label(for='email') Email address
           input#email.form__input.e_signup(type='email', placeholder='you@example.com', required)
        .form__group.ma-bt-md
          label.form__label(for='password') Password
          input#password.form__input.p_signup(type='password', placeholder='••••••••', required, minlength='8')
        .form__group.ma-bt-md
          label.form__label(for='password-confirm') Confirm Password
          input#password-confirm.form__input.c_signup(type='password', placeholder='••••••••', required, minlength='8')
        .form__group
           button.btn.btn--green Sign Up